# ==========================
# Configuration Production VPS
# ==========================

NODE_ENV=production
PORT=5000

# ==========================
# MongoDB Atlas
# ==========================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio

# ==========================
# JWT - IMPORTANT: Générer un secret unique
# Commande: openssl rand -base64 32
# ==========================
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET
JWT_EXPIRES_IN=24h

# ==========================
# Email (optionnel)
# ==========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ==========================
# Cloudinary (optionnel - pour les images)
# ==========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================
# Frontend URL
# Remplacer YOUR_VPS_IP par l'IP de ton VPS
# Ou ton domaine quand tu en auras un
# ==========================
CLIENT_URL=http://YOUR_VPS_IP
